{
  "command": "client-run",
  "server": "localhost:50051",
  "model": "mobilenet_v2",
  "bandwidth_mbps": 100,
  "cpu_load_target": 60,
  "cpu_load_tolerance": 5,
  "cpu_load_interval": 0.5,
  "cpu_load_ramp_seconds": 2,
  "input_shape": [4, 3, 224, 224],
  "profile_runs": 5,
  "profile_warmup_runs": 3,
  "report_format": "csv",
  "report_output": "results/mobilenet_v2_100mbps.csv",
  "debug_output": "results/debug_mobilenet_v2_100mbps.json"
}
