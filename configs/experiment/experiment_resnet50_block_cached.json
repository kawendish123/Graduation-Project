{
  "command": "experiment",
  "profile_mode": "cached",
  "server": "connect.westb.seetacloud.com:30112",
  "model": "resnet50",
  "partition_granularity": "block",
  "bandwidths_mbps": [5, 10, 20, 50, 100],
  "cpu_load_targets":[0, 10, 20, 30],
  "repeats": 5,
  "actual_warmup_runs": 2,
  "input_shape": [1, 3, 224, 224],
  "profile_runs": 5,
  "profile_warmup_runs": 3,
  "cpu_load_tolerance": 5,
  "cpu_load_interval": 0.5,
  "cpu_load_ramp_seconds": 2,
  "edge_profiles": {
    "0": "profiles/resnet50_block/edge_load0.json",
    "10": "profiles/resnet50_block/edge_load10.json",
    "20": "profiles/resnet50_block/edge_load20.json",
    "30": "profiles/resnet50_block/edge_load30.json"
  },
  "cloud_profile": "profiles/resnet50_block/cloud_cuda.json",
  "report_csv": "results/experiment_resnet50_block_cached.csv",
  "report_json": "results/experiment_resnet50_block_cached.json",
  "debug_dir": "results/debug_resnet50_block_cached",
  "plot_dir": "results/plots_resnet50_block_cached",
  "plot_format": "png"
}
